# ========================================
# Content Syndicator - 开发环境变量模板
# ========================================
# 复制此文件为 .dev.env 并填写实际的凭证
# cp .dev.env.example .dev.env

# ========================================
# 基础配置
# ========================================
NODE_ENV=development
LOG_LEVEL=debug

# ========================================
# LLM 配置（选择一个或两个都配置）
# ========================================
# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_BASE_URL=https://api.openai.com/v1

# Gemini（可选备选方案）
GEMINI_API_KEY=AIzaSy...

# ========================================
# 发布平台认证（按需填写）
# ========================================
# Blogger
GOOGLE_APPLICATION_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}
BLOGGER_BLOG_ID=123456789

# Dev.to
DEVTO_API_KEY=token_...

# Medium
MEDIUM_API_TOKEN=...

# Telegraph（Telegraph.cr 一行式 token）
TELEGRAPH_API_TOKEN=...

# WordPress
WORDPRESS_SITE_URL=https://example.wordpress.com
WORDPRESS_USERNAME=admin
WORDPRESS_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# GitHub
GITHUB_TOKEN=ghp_...
GITHUB_REPO=owner/repo

# Hashnode
HASHNODE_API_KEY=...
HASHNODE_PUBLICATION_ID=...

# ========================================
# Google Sheets 配置（用于数据聚合）
# ========================================
SHEETS_SPREADSHEET_ID=1234567890abcdefg
SHEETS_API_KEY=AIzaSy...

# ========================================
# 浏览器自动化配置
# ========================================
BROWSER_HEADLESS=false
ENABLE_BROWSER_AUTOMATION=true
CHROME_BIN=/usr/bin/chromium  # Docker 环境
# CHROME_BIN=/Applications/Google\ Chrome.app/Contents/MacOS/Google\ Chrome  # macOS

# ========================================
# 调试和监控
# ========================================
DEBUG=content-syndicator:*
ENABLE_METRICS=true
ENABLE_HEALTH_CHECK=true

# ========================================
# 超时和重试配置
# ========================================
REQUEST_TIMEOUT_MS=30000
MAX_RETRIES=3
MIN_SLEEP_MS=1000
MAX_SLEEP_MS=5000

# ========================================
# 数据库配置（开发默认使用 SQLite）
# ========================================
DB_TYPE=sqlite
DB_PATH=.data/syndicator.db
DB_WAL_MODE=true

# ========================================
# 服务器配置
# ========================================
PORT=3000
HOST=0.0.0.0
MAX_CONCURRENT_JOBS=3

# ========================================
# 功能开关
# ========================================
ENABLE_VOICE_SYNDICATOR=true
ENABLE_SCHEDULER=true
ENABLE_LIVENESS_WORKER=true
ENABLE_DAILY_DIGEST=true
