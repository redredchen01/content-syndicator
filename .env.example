OPENAI_API_KEY=
DEVTO_API_KEY=
MEDIUM_INTEGRATION_TOKEN=
GOOGLE_SHEET_ID=

# Blogger via OAuth2 (recommended — supports personal Google accounts)
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Type: OAuth 2.0 Client ID > Web application
# Authorized redirect URI: http://localhost:3000/api/auth/google/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
BLOGGER_BLOG_ID=

# Optional: public URL when deployed (used to build the OAuth redirect URI)
# APP_BASE_URL=https://your-domain.com

# Blogger via Service Account (alternative — only works for Google Workspace blogs)
GOOGLE_APPLICATION_CREDENTIALS_JSON=
