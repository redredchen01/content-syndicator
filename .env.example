OPENAI_API_KEY=
GOOGLE_SHEET_ID=

# ── Encryption ─────────────────────────────────────────────────────────────
# AES-256-GCM key for api_keys_encrypted + oauth_tokens.refresh_token columns.
# Required to decrypt stored credentials — back this up alongside the database.
# Generate with: openssl rand -hex 32
# Server refuses to start in production (NODE_ENV=production) when unset/default.
ENCRYPTION_KEY=

# ── OAuth endpoint gate ────────────────────────────────────────────────────
# OAuth ops endpoints (/api/auth/google/start, DELETE /api/auth/oauth/:platform)
# default to loopback-only (127.0.0.1). Set to true ONLY when this server sits
# behind a reverse proxy that enforces its own authentication.
OAUTH_ALLOW_REMOTE=false

# ── Browser automation (used by Medium fallback + Substack/IH/etc.) ────────
ENABLE_BROWSER_AUTOMATION=true

# ── Medium ─────────────────────────────────────────────────────────────────
# Legacy integration token — Medium stopped issuing new ones in 2023.
# Existing tokens still work; new users should leave blank and click
# "Connect with Browser Login" in admin UI to capture a session instead.
MEDIUM_INTEGRATION_TOKEN=

# ── Blogger (recommended path: Google OAuth 2.0 user flow) ─────────────────
# Works with personal Google accounts (unlike service-account, which only
# works on Google Workspace blogs the SA was explicitly granted).
# Setup: console.cloud.google.com → create project → enable Blogger API v3
#   → OAuth consent screen (External / Testing, add your email as test user)
#   → Credentials → Create OAuth Client ID → Web application
#   → Authorized redirect URI must match OAUTH_REDIRECT_URI exactly
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# Optional: public URL when deployed — set OAUTH_REDIRECT_URI to
# ${APP_BASE_URL}/api/auth/google/callback and register that URL with Google.
# APP_BASE_URL=https://your-domain.com

# Required for Blogger publishing (the ID in your Blogger dashboard URL)
BLOGGER_BLOG_ID=

# ── Blogger fallback (service account) ─────────────────────────────────────
# Only works if the blog is owned by the service account or has been shared
# with the service account email. OAuth user flow above is preferred.
GOOGLE_APPLICATION_CREDENTIALS_JSON=

# ── Tier 1 platforms (PAT only — no OAuth API) ─────────────────────────────
# Generate Dev.to API Key:  https://dev.to/settings/extensions
# Generate Hashnode PAT:    https://hashnode.com/settings/developer
# admin.html surfaces "获取 API Key ↗" links pointing at the URLs above.
DEVTO_API_KEY=
HASHNODE_TOKEN=
HASHNODE_PUBLICATION_ID=

# ── WordPress.com OAuth 2.0 (recommended for WordPress.com users) ──────────
# Setup: https://developer.wordpress.com/apps/ → Create New Application
#   → Type: Web → Redirect URLs: http://localhost:3000/api/auth/wordpress/callback
#   → Save → copy Client ID + Client Secret
# Note: WordPress.com OAuth does not return a refresh_token; access_tokens
# are long-lived until the user revokes the app at
# https://wordpress.com/me/security/connected-applications.
WORDPRESS_OAUTH_CLIENT_ID=
WORDPRESS_OAUTH_CLIENT_SECRET=
WORDPRESS_OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/wordpress/callback

# ── WordPress self-hosted (fallback — Application Password) ────────────────
# Used automatically when no WordPress.com OAuth row is stored. Generate an
# Application Password at WP Admin → Users → Profile → Application Passwords.
WORDPRESS_SITE_URL=
WORDPRESS_USERNAME=
WORDPRESS_APP_PASSWORD=

# ── GitHub OAuth 2.0 (recommended for Gist publishing) ─────────────────────
# Setup: https://github.com/settings/developers → New OAuth App
#   → Authorization callback URL: http://localhost:3000/api/auth/github/callback
#   → Save → Generate a new client secret
# Scope requested: gist (minimum required for Gist publishing).
# Like WordPress.com, GitHub OAuth Apps do not return refresh_tokens;
# access_tokens are long-lived until the user revokes the app at
# https://github.com/settings/applications.
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/github/callback

# ── GitHub PAT (fallback — legacy) ─────────────────────────────────────────
# Used automatically when no GitHub OAuth row is stored. Existing PAT users
# need no migration — the adapter prefers OAuth when present, falls back here.
GITHUB_TOKEN=

# ── Twitter / X ────────────────────────────────────────────────────────────
# Recommended: OAuth 2.0 PKCE — one-click Connect with X in admin UI.
# Setup: developer.x.com → Project + App → User authentication settings
#   → Type of App: Web App
#   → Callback URI: must match TWITTER_OAUTH_REDIRECT_URI exactly
#   → App permissions: Read and write
#   → Save → Keys and tokens → OAuth 2.0 Client ID and Client Secret
TWITTER_OAUTH_CLIENT_ID=
TWITTER_OAUTH_CLIENT_SECRET=
TWITTER_OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/twitter/callback

# OAuth 1.0a (legacy) — still works as a fallback when no oauth_tokens row
# exists. Either flow works; OAuth 2.0 above is preferred for new setups.
TWITTER_CONSUMER_KEY=
TWITTER_CONSUMER_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=

# Instapaper Simple API
INSTAPAPER_USERNAME=
INSTAPAPER_PASSWORD=
